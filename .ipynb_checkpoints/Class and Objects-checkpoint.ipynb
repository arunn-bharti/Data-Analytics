   "source": [
    "class Person():\n",
    "    def __init__(self,name,age):\n",
    "        self.name=name\n",
    "        self.age=age\n",
    "    def talk(self):\n",
    "        print(\"hi\")\n",
    "\n",
    "obj=Person(\"Raj\",20)\n",
    "Person.talk(obj)\n",
    "print(obj.name,obj.age)"
   ]
